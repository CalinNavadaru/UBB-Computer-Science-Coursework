    <appSettings>
        <add key="selectP" value="SELECT * FROM Posturi;"/>
        <add key="selectC" value="SELECT * FROM Responsabilitati WHERE poid = @id"/>
        <add key="deleteC" value="DELETE FROM Responsabilitati WHERE id = @id;"/>
        <add key="insertC" value="INSERT INTO Responsabilitati(nume, poid) VALUES (@nume, @f_id)"/>
        <add key="updateC" value="UPDATE Responsabilitati SET nume = @nume WHERE id= @id;"/>
        <add key="tableP" value="Posturi"/>
        <add key="tableC" value="Responsabilitati"/>
    </appSettings>
</configuration>